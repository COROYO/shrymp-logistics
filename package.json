{
  "name": "monolith",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @monolith/logistics dev",
    "dev:logistics": "pnpm --filter @monolith/logistics dev",
    "dev:website": "pnpm --filter @monolith/website dev",
    "build": "pnpm --filter @monolith/logistics build",
    "build:logistics": "pnpm --filter @monolith/logistics build",
    "build:website": "pnpm --filter @monolith/website build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @monolith/logistics test"
  }
}
