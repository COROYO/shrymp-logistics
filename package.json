{
  "name": "Shrymp Logistics",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @shrymp/logistics dev",
    "dev:logistics": "pnpm --filter @shrymp/logistics dev",
    "dev:website": "pnpm --filter @monolith/website dev",
    "build": "pnpm --filter @shrymp/logistics build",
    "start": "pnpm --filter @shrymp/logistics start",
    "build:logistics": "pnpm --filter @shrymp/logistics build",
    "build:website": "pnpm --filter @monolith/website build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @shrymp/logistics test"
  }
}
