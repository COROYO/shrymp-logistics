# ---------- Firebase (server / Admin SDK) ----------
FIREBASE_PROJECT_ID=monolith-lager
# Inline service account JSON (single line). Generate in Firebase Console →
# Project Settings → Service Accounts → Generate new private key.
# On Firebase Hosting / Cloud Functions ADC is used automatically — leave empty.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ---------- Firebase (client SDK, exposed to browser) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=monolith-lager.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=monolith-lager
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=monolith-lager.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------- Shopify App (Partner Dashboard / Shopify CLI) ----------
SHOPIFY_SHOP_DOMAIN=monolithcaviar.myshopify.com
# Client ID and Client Secret of the Shopify App.
# Client Secret is ALSO used for verifying webhook HMAC signatures.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Comma-separated list of OAuth scopes. read_products + write_orders covers
# product sync, order tagging, fulfillment create, inventory set.
SHOPIFY_SCOPES=read_products,read_orders,write_orders,read_inventory,write_inventory,read_fulfillments,write_fulfillments,read_locations
SHOPIFY_API_VERSION=2026-04

# ---------- Cloud Tasks (allocation queue) ----------
GCP_PROJECT_ID=monolith-lager
GCP_LOCATION=europe-west3
ALLOCATION_QUEUE=allocation-runs
ALLOCATION_TARGET_URL=https://europe-west3-monolith-lager.cloudfunctions.net/runAllocation
ALLOCATION_INVOKER_SERVICE_ACCOUNT=

# Public base URL of THIS app (used to register Shopify webhooks).
# e.g. https://monolith.shyrmp.de or https://monolith-lager.web.app.
APP_BASE_URL=monolith.shyrmp.de

# Set to "1" to disable OIDC verification on /api/internal/allocation/run
# (development only — do NOT enable in production).
ALLOCATION_ALLOW_UNAUTHENTICATED=

# ---------- Misc ----------
NODE_ENV=development
