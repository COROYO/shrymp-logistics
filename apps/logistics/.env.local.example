# ---------- Firebase (server / Admin SDK) ----------
FIREBASE_PROJECT_ID=shrymp-logistics
# Inline service account JSON (single line, single-quoted). Generate in
# Firebase Console → Project Settings → Service Accounts → Generate new key.
# On Firebase Hosting / Cloud Functions ADC is used automatically — leave empty.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ---------- Firebase (client SDK, exposed to browser) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDQlU_eDgL7h568U8pPlaWYKtq1fRSuqwo
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=shrymp-logistics.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=shrymp-logistics
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=shrymp-logistics.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=308132633024
NEXT_PUBLIC_FIREBASE_APP_ID=1:308132633024:web:69952d85ad26f1995c9025

# ---------- Shopify Custom App (pre-installed in the shop) ----------
# Admin API access token from the Custom App's API-credentials page in the
# Shopify Admin (or Partner Dashboard if the app was installed via there).
# Required for ALL Admin GraphQL calls.
SHOPIFY_ADMIN_ACCESS_TOKEN=
# Client Secret of the App — used to verify webhook HMAC signatures.
SHOPIFY_API_SECRET=
# Client ID — optional, kept for identification only.
SHOPIFY_API_KEY=
SHOPIFY_API_VERSION=2026-04

# ---------- Cloud Tasks (allocation queue) ----------
GCP_PROJECT_ID=shrymp-logistics
GCP_LOCATION=europe-west3
ALLOCATION_QUEUE=allocation-runs
ALLOCATION_TARGET_URL=https://europe-west3-shrymp-logistics.cloudfunctions.net/runAllocation
ALLOCATION_INVOKER_SERVICE_ACCOUNT=

# Public base URL of THIS app (used to register Shopify webhooks and background jobs).
APP_BASE_URL=

# Shared secret for /api/cron/* and /api/internal/* routes (?secret=… or Bearer).
CRON_SECRET=

# Set to "1" to disable OIDC verification on /api/internal/allocation/run
# (development only — do NOT enable in production).
ALLOCATION_ALLOW_UNAUTHENTICATED=

# ---------- Misc ----------
NODE_ENV=development
